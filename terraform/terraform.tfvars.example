env         = "prod"
aws_region  = "ap-northeast-2"
app_name    = "ticketing"
github_repo = "your-org/ticketing"

# RDS 비번은 modules/rds 가 random_password로 자동 생성하고 SSM(/ticketing/prod/db/password)에 저장.
# ESO가 ticketing-secrets K8s Secret으로 자동 주입한다. 더 이상 tfvars에 평문으로 넣지 않는다.
# 비번 회전이 필요하면: terraform taint 'module.rds.random_password.db' && terraform apply

# 기본값 ticketing-eks. 이미 prod-ticketing-eks 로 클러스터가 있으면 교체 방지용으로 아래 주석 해제:
# eks_cluster_name = "prod-ticketing-eks"

# Cognito 호스티드 UI 접두사(리전 내 유일). 이미 prod- 접두사 도메인을 쓰면:
# cognito_domain_prefix = "prod-ticketing-auth"
